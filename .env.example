# Local Neo4j (started by scripts/00_bootstrap_neo4j.sh on port 7693)
NEO4J_URI=bolt://localhost:7693
NEO4J_USER=neo4j
NEO4J_PASSWORD=neograph_local_dev
NEO4J_DATABASE=neo4j

# Required for the `uv pip install -e .` setup; see HANDOVER.md §7 for the rationale.
PYTHONPATH=src

# Optional: Anthropic API key only used as an autointerp fallback when Neuronpedia
# has no cached label. The pipeline runs fine without it.
# ANTHROPIC_API_KEY=

# Hugging Face token for gated Gemma 2 weights. Required to run any Gemma model.
# Get one at https://huggingface.co/settings/tokens (read-only is fine).
HF_TOKEN=
